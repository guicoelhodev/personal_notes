---
import SaveIcon from "../icons/save.svg?raw";
import SpinnerIcon from "../icons/spinner.svg?raw";

interface Props {
	path?: string;
}

const { path } = Astro.props;
---

<div id="page-actions" class="sticky bottom-0 flex items-center justify-between px-4 py-3 w-full min-w-0 bg-transparent">
	<h1 id="page-title" class="text-sm font-medium text-(--color-text) truncate px-3 py-1.5 rounded-md bg-(--color-muted)/10">
		{path || "No file selected"}
	</h1>

		<button
			id="save-btn"
			type="button"
			aria-label="Save"
			class="save-btn flex items-center gap-2 p-2 rounded-lg bg-(--color-surface) hover:opacity-80 transition-opacity cursor-pointer text-(--color-muted) disabled:opacity-50 disabled:cursor-not-allowed"
		>
			<span id="save-icon" class="w-4 h-4" set:html={SaveIcon} />
			<span id="save-spinner" class="w-4 h-4 animate-spin hidden" set:html={SpinnerIcon} />
			<kbd class="text-xs border border-(--color-muted)/40 rounded px-1.5 py-0.5 hidden sm:inline">Ctrl+S</kbd>
		</button>
	</div>

	<div id="toast" class="fixed bottom-16 right-4 px-4 py-2 rounded-lg bg-(--color-surface) border border-(--color-muted)/20 text-(--color-text) text-sm hidden opacity-0 transition-opacity duration-300"></div>

	<script>
	function setupPageActions() {
		const saveBtn = document.getElementById("save-btn") as HTMLButtonElement;
		const saveIcon = document.getElementById("save-icon");
		const saveSpinner = document.getElementById("save-spinner");
		if (!saveBtn || !saveIcon || !saveSpinner) return;

		function setLoading(loading: boolean) {
			saveBtn.disabled = loading;
			saveIcon?.classList.toggle("hidden", loading);
			saveSpinner?.classList.toggle("hidden", !loading);
		}

		function showToast(message: string) {
			const toast = document.getElementById("toast");
			if (!toast) return;
			toast.textContent = message;
			toast.classList.remove("hidden");
			requestAnimationFrame(() => toast.classList.remove("opacity-0"));
			setTimeout(() => {
				toast.classList.add("opacity-0");
				setTimeout(() => toast.classList.add("hidden"), 300);
			}, 2000);
		}

		function save() {
			if (saveBtn.disabled) return;
			const markdown = (window as any).__editor?.getMarkdown();
			if (!markdown) return;

			const original = (window as any).__originalContent ?? "";
			if (markdown.trim() === original.trim()) {
				showToast("No changes to save");
				return;
			}

			const path = (window as any).__filePath ?? "";
			if (!path) return;

			setLoading(true);
			fetch("/api/save", {
				method: "PUT",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ path, content: markdown }),
			})
				.then((res) => res.json())
				.then((data) => {
					if (data.error) throw new Error(data.error);
					(window as any).__originalContent = markdown;
					showToast("Saved successfully");
				})
				.catch((err) => {
					showToast(err.message || "Failed to save");
				})
				.finally(() => {
					setLoading(false);
				});
		}

		saveBtn.addEventListener("click", save);

		document.addEventListener("keydown", ((e: KeyboardEvent) => {
			if ((e.ctrlKey || e.metaKey) && e.key === "s") {
				e.preventDefault();
				save();
			}
		}) as EventListener);
	}

	setupPageActions();
	document.addEventListener("astro:page-load", setupPageActions);
</script>
