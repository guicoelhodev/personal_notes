---
import MoonIcon from "../icons/moon.svg?raw";
import SunIcon from "../icons/sun.svg?raw";
---

<button id="theme-toggle" type="button" aria-label="Toggle theme" class="grid place-content-center p-2 rounded-lg bg-[var(--color-surface)] hover:opacity-80 transition-opacity cursor-pointer">
	<span id="icon-moon" class="w-5 h-5" set:html={MoonIcon} />
	<span id="icon-sun" class="w-5 h-5" style="display:none" set:html={SunIcon} />
</button>

<script>
	function getTheme() {
		return localStorage.getItem("theme") || "dark";
	}

	function applyTheme(theme: string) {
		document.documentElement.classList.remove("light");
		if (theme === "light") {
			document.documentElement.classList.add("light");
		}
		const moon = document.getElementById("icon-moon");
		const sun = document.getElementById("icon-sun");
		if (moon && sun) {
			moon.style.display = theme === "light" ? "none" : "inline-block";
			sun.style.display = theme === "dark" ? "none" : "inline-block";
		}
	}

	function toggleTheme() {
		const next = getTheme() === "dark" ? "light" : "dark";
		localStorage.setItem("theme", next);
		applyTheme(next);
	}

	applyTheme(getTheme());
	document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
</script>
