---
interface Props {
	items: { id: string; title: string }[];
}

const { items } = Astro.props;
---

<div id="search-overlay" class="fixed inset-0 bg-black/50 z-50 hidden items-start justify-center pt-[20vh]">
	<div id="search-modal" class="w-full max-w-lg mx-4 rounded-lg border border-[var(--color-muted)]/30 bg-[var(--color-surface)] shadow-2xl overflow-hidden">
		<div class="flex items-center gap-2 px-4 py-3 border-b border-[var(--color-muted)]/20">
			<svg class="w-4 h-4 text-[var(--color-muted)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
			</svg>
			<input
				id="search-input"
				type="text"
				placeholder="Search notes..."
				autocomplete="off"
				spellcheck="false"
				class="flex-1 bg-transparent outline-none text-[var(--color-text)] placeholder:text-[var(--color-muted)]"
			/>
			<kbd class="text-xs text-[var(--color-muted)] border border-[var(--color-muted)]/30 rounded px-1.5 py-0.5">ESC</kbd>
		</div>
		<ul id="search-results" class="max-h-64 overflow-y-auto">
		</ul>
	</div>
</div>

<script is:inline define:vars={{ items }}>
	window.__SEARCH_ITEMS__ = items;
</script>

<script>
	import Fuse from "fuse.js";

	const items = (window as any).__SEARCH_ITEMS__ as { id: string; title: string }[];
	delete (window as any).__SEARCH_ITEMS__;

	const fuse = new Fuse(items, {
		keys: ["title"],
		threshold: 0.2,
		includeMatches: true,
		ignoreLocation: true,
		isCaseSensitive: false,
	});

	const overlay = document.getElementById("search-overlay");
	const input = document.getElementById("search-input");
	const results = document.getElementById("search-results");

	if (overlay && input && results) {
		let open = false;
		let activeIndex = -1;

		function show() {
			open = true;
			overlay.classList.remove("hidden");
			overlay.classList.add("flex");
			input.value = "";
			results.innerHTML = "";
			activeIndex = -1;
			input.focus();
		}

		function hide() {
			open = false;
			overlay.classList.add("hidden");
			overlay.classList.remove("flex");
		}

		function escapeHtml(str: string) {
			return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
		}

		function renderResults(list: Fuse.FuseResult<{ id: string; title: string }>[]) {
			results.innerHTML = "";
			activeIndex = -1;

			if (list.length === 0) {
				results.innerHTML = '<li class="px-4 py-3 text-sm text-[var(--color-muted)]">No results</li>';
				return;
			}

			list.forEach((item, i) => {
				const li = document.createElement("li");
				const title = item.item.title;
				const match = item.matches?.[0];

				let html = title;
				if (match?.indices?.length) {
					let result = "";
					let last = 0;
					for (const [start, end] of match.indices) {
						result += escapeHtml(title.slice(last, start));
						result += `<mark class="bg-[var(--color-heading)]/30 text-[var(--color-heading)] rounded-sm">${escapeHtml(title.slice(start, end + 1))}</mark>`;
						last = end + 1;
					}
					result += escapeHtml(title.slice(last));
					html = result;
				}

				li.innerHTML = `<a href="/${item.item.id}" class="block px-4 py-2.5 text-sm text-[var(--color-text)] hover:bg-[var(--color-heading)]/10 cursor-pointer transition-colors">${html}</a>`;
				li.dataset.index = String(i);
				results.appendChild(li);
			});
		}

		function updateActive(items: NodeListOf<Element>) {
			items.forEach((el) => el.querySelector("a")?.classList.remove("bg-[var(--color-heading)]/10"));
			if (items[activeIndex]) {
				const el = items[activeIndex].querySelector("a");
				el?.classList.add("bg-[var(--color-heading)]/10");
				el?.scrollIntoView({ block: "nearest" });
			}
		}

		let debounceTimer: ReturnType<typeof setTimeout> | null = null;

		input.addEventListener("input", () => {
			clearTimeout(debounceTimer!);
			const query = input.value.trim();
			if (!query) {
				results.innerHTML = "";
				activeIndex = -1;
				return;
			}
			debounceTimer = setTimeout(() => {
				renderResults(fuse.search(query));
			}, 150);
		});

		overlay.addEventListener("click", (e) => {
			if (e.target === overlay) hide();
		});

		input.addEventListener("keydown", (e) => {
			const resultItems = results.querySelectorAll("li[data-index]");
			if (e.key === "ArrowDown") {
				e.preventDefault();
				activeIndex = Math.min(activeIndex + 1, resultItems.length - 1);
				updateActive(resultItems);
			} else if (e.key === "ArrowUp") {
				e.preventDefault();
				activeIndex = Math.max(activeIndex - 1, 0);
				updateActive(resultItems);
			} else if (e.key === "Enter" && activeIndex >= 0 && resultItems[activeIndex]) {
				const link = resultItems[activeIndex].querySelector("a");
				if (link) (link as HTMLAnchorElement).click();
			}
		});

		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && open) {
				hide();
				e.preventDefault();
				return;
			}
			if ((e.metaKey || e.ctrlKey) && e.key === "k") {
				e.preventDefault();
				if (open) hide();
				else show();
			}
		});

		document.getElementById("search-trigger")?.addEventListener("click", show);
	}
</script>
