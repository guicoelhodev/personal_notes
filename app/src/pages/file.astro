---
import Layout from "../layout/Layout.astro";
import PageActions from "../components/PageActions.astro";
import { getFile } from "../lib/github";
import "../milkdown.css";

export const prerender = false;

const path = Astro.url.searchParams.get("path");
const mode = Astro.url.searchParams.get("mode");

let content = "";

if (path && mode !== "create") {
	try {
		content = await getFile(path);
	} catch (error: any) {
		content = `# Error\n\nFile not found: ${path}`;
	}
} else if (path && mode === "create") {
	const fileName = path.replace(/^.*\//, "").replace(/\.md$/, "");
	const formattedName = fileName.replace(/[-_]/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
	content = `# ${formattedName}\n`;
}
---

<Layout title={path ? `${path} — AI Notes` : "AI Notes"}>
	<div class="h-full flex flex-col justify-between">
		<div class="flex-1 min-h-0 overflow-y-auto">
			<div id="editor" class="h-full"></div>
		</div>

		<PageActions path={path ?? '/file-not-found'} />
	</div>

	<div id="editor-content" class="hidden">{content}</div>

	<script>
		import { Crepe } from "@milkdown/crepe";

		function injectSidebarNode(filePath: string, formattedName: string) {
			const parts = filePath.replace(/\.md$/, "").split("/");
			const fileName = parts.pop();
			const parentPath = parts.join("/");

			const sidebarUls = document.querySelectorAll("ul[data-folder-path]");
			let targetUl: Element | null = null;
			for (const ul of sidebarUls) {
				if (ul.getAttribute("data-folder-path") === parentPath) {
					targetUl = ul;
					break;
				}
			}

			if (!targetUl) return;

			targetUl.classList.remove("hidden");
			const parentLi = targetUl.closest("li")?.querySelector("div");
			if (parentLi) {
				const arrow = parentLi.querySelector(".arrow") as HTMLElement | null;
				if (arrow) arrow.style.transform = "";
				const toggleBtn = parentLi.querySelector("button");
				if (toggleBtn) toggleBtn.setAttribute("aria-expanded", "true");
			}

			if (targetUl.querySelector(`a[href="/file?path=${encodeURIComponent(filePath)}"]`)) return;

			const li = document.createElement("li");
			const a = document.createElement("a");
			a.href = `/file?path=${encodeURIComponent(filePath)}`;
			a.className = "block text-sm py-1 px-2 rounded transition-colors text-(--color-text) bg-(--color-heading)/20 font-medium";
			a.textContent = formattedName;
			li.appendChild(a);
			targetUl.prepend(li);
		}

		async function loadEditor(path: string, content: string, mode: string) {
			const editorEl = document.getElementById("editor");
			if (!editorEl) return;

			const oldEditor = (window as any).__editor;
			if (oldEditor) {
				try { await oldEditor.destroy(); } catch {}
			}

			editorEl.innerHTML = "";

			const placeholder = mode === "create" ? "Type here, use / for more options" : "";

			const newEditor = new Crepe({
				root: "#editor",
				defaultValue: content,
				placeholder,
			});
			newEditor.create();

			(window as any).__editor = newEditor;
			(window as any).__originalContent = content;
			(window as any).__filePath = path;
			(window as any).__mode = mode;

			const pageTitle = document.getElementById("page-title");
			if (pageTitle) pageTitle.textContent = path;

			history.pushState({}, "", `/file?path=${encodeURIComponent(path)}&mode=${mode}`);

			if (mode === "create") {
				const parts = path.replace(/\.md$/, "").split("/");
				const fileName = parts.pop();
				const formattedName = fileName!.replace(/[-_]/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase());
				injectSidebarNode(path, formattedName);
			}
		}

		(window as any).__loadEditor = loadEditor;

		const el = document.getElementById("editor-content");
		const content = el ? el.textContent : "# Select a file";
		el?.remove();

		const editor = new Crepe({
			root: "#editor",
			defaultValue: content,
		});

		editor.create();
		(window as any).__editor = editor;
		(window as any).__originalContent = content;
		(window as any).__filePath = new URLSearchParams(window.location.search).get("path") || "";
		(window as any).__mode = new URLSearchParams(window.location.search).get("mode") || "";

		if ((window as any).__mode === "create") {
			const filePath = (window as any).__filePath;
			if (!filePath) throw new Error("Missing path for create mode");
			const parts = filePath.replace(/\.md$/, "").split("/");
			const fileName = parts.pop();
			const formattedName = fileName!.replace(/[-_]/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase());
			injectSidebarNode(filePath, formattedName);
		}
	</script>
</Layout>
