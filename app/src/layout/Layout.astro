---
import "../global.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import Sidebar from "../components/Sidebar.astro";
import SearchModal from "../components/SearchModal.astro";
import SearchIcon from "../icons/search.svg?raw";
import MenuIcon from "../icons/menu.svg?raw";
import { getCollection, render } from "astro:content";

interface Props {
	title: string;
	currentSlug?: string;
}
const { title, currentSlug } = Astro.props;

const docs = await getCollection("docs");
const searchItems = await Promise.all(
	docs.map(async (doc) => {
		const { headings } = await render(doc);
		const t = headings.find((h) => h.depth === 1)?.text || doc.id;
		return { id: doc.id, title: t };
	}),
);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script is:inline>
			(function () {
				var t = localStorage.getItem("theme");
				if (t === "light") document.documentElement.classList.add("light");
			})();
		</script>
	</head>
	<body class="flex h-screen overflow-hidden">
		<aside
			id="sidebar"
			class="fixed inset-y-0 right-0 z-40 w-full md:w-64 md:static md:shrink-0 border-r border-[var(--color-muted)]/20 bg-[var(--color-surface)]"
		>
			<Sidebar currentSlug={currentSlug} />
		</aside>

		<div
			id="sidebar-overlay"
			class="fixed inset-0 bg-black/50 z-30 hidden"
		></div>

		<main class="flex-1 overflow-y-auto p-8">
			<div class="fixed top-4 right-4 z-50 flex items-center gap-2">
				<button
					id="search-trigger"
					type="button"
					aria-label="Search"
					class="flex items-center gap-2 p-2 rounded-lg bg-[var(--color-surface)] hover:opacity-80 transition-opacity cursor-pointer text-[var(--color-muted)]"
				>
					<span class="w-4 h-4 inline-block" set:html={SearchIcon} />
					<kbd class="text-xs border border-[var(--color-muted)]/40 rounded px-1.5 py-0.5 hidden sm:inline">Ctrl+K</kbd>
				</button>
				<ThemeToggle />
				<button
					id="sidebar-toggle"
					class="md:hidden p-2 rounded-lg bg-[var(--color-surface)] hover:opacity-80 transition-opacity cursor-pointer text-[var(--color-text)]"
					aria-label="Toggle menu"
				>
					<span class="w-5 h-5 inline-block" set:html={MenuIcon} />
				</button>
			</div>
			<slot />
		</main>

		<SearchModal items={searchItems} />

		<style is:inline>
			@media (max-width: 767px) {
				#sidebar {
					transform: translateX(100%);
					transition: transform 0.2s ease;
				}
				#sidebar.open {
					transform: translateX(0);
				}
			}
		</style>

		<script is:inline>
			function setupSidebar() {
				var sidebar = document.getElementById("sidebar");
				var overlay = document.getElementById("sidebar-overlay");
				var toggle = document.getElementById("sidebar-toggle");
				var isOpen = false;

				function open() {
					sidebar.classList.add("open");
					overlay.classList.remove("hidden");
					isOpen = true;
				}

				function closeSidebar() {
					sidebar.classList.remove("open");
					overlay.classList.add("hidden");
					isOpen = false;
				}

				toggle.addEventListener("click", function () {
					if (isOpen) closeSidebar();
					else open();
				});
				overlay.addEventListener("click", closeSidebar);

				sidebar.querySelectorAll("a").forEach(function (a) {
					a.addEventListener("click", closeSidebar);
				});
			}
			setupSidebar();

			function setupCopyButtons() {
				document.querySelectorAll(".prose pre").forEach(function (pre) {
					if (pre.querySelector("button.copy-btn")) return;
					var btn = document.createElement("button");
					btn.className = "copy-btn";
					btn.textContent = "Copy";
					btn.addEventListener("click", function () {
						var code = pre.querySelector("code");
						if (!code) return;
						navigator.clipboard.writeText(code.textContent).then(function () {
							btn.textContent = "Copied!";
							setTimeout(function () { btn.textContent = "Copy"; }, 2000);
						});
					});
					pre.style.position = "relative";
					pre.appendChild(btn);
				});
			}
			setupCopyButtons();
			document.addEventListener("astro:page-load", setupCopyButtons);
		</script>
	</body>
</html>

